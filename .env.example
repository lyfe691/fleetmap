# Supabase — copy this file to .env and fill in from the Supabase dashboard
# (Project Settings -> API Keys).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Dev/scripts only (e.g. scripts/fake-gps.ts). Bypasses RLS — never import this
# in a route handler or ship it in a deployed image.
SUPABASE_SECRET_KEY=
