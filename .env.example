# Supabase — copy this file to .env and fill in from the Supabase dashboard
# (Project Settings -> API Keys).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Dev/scripts only (e.g. scripts/fake-gps.ts, scripts/provision-dashboard.ts).
# Bypasses RLS — never import this in a route handler or ship it in a deployed image.
SUPABASE_SECRET_KEY=

# Map tiles (client-visible). Restrict the key by domain in the MapTiler
# dashboard before any public deploy. Never the public OSM tile server.
NEXT_PUBLIC_MAPTILER_KEY=

# Read-only dashboard ("display token") — SERVER-ONLY. Do NOT prefix any of these
# NEXT_PUBLIC_ or they leak into the client bundle and defeat the gate.
DASHBOARD_EMAIL=dashboard@fleetmap.internal
DASHBOARD_PASSWORD=
DASHBOARD_DISPLAY_CODE=
